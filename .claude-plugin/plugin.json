{
  "name": "token-watch",
  "version": "0.3.2",
  "description": "Live token, context-window and cost monitoring for Claude Code — statusline gauge, auto-compact suggestions, and usage reports. Zero dependencies.",
  "author": {
    "name": "SolSolis-Sys",
    "url": "https://github.com/SolSolis-Sys"
  },
  "homepage": "https://github.com/SolSolis-Sys/claude-token-watch",
  "repository": "https://github.com/SolSolis-Sys/claude-token-watch",
  "license": "MIT",
  "keywords": ["tokens", "cost", "monitoring", "statusline", "context-window", "usage", "compact"],
  "statusLine": {
    "type": "command",
    "command": "node \"${CLAUDE_PLUGIN_ROOT}/statusline/statusline.js\""
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/loop-advisor.js\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/context-guard.js\""
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/session-logger.js\""
          }
        ]
      }
    ]
  }
}
